# Copy to .env in your project root after migrating to your own Supabase.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-REF

# Edge-function-only secrets (set with: supabase secrets set NAME=value)
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY are auto-injected.
# LOVABLE_API_KEY is Lovable-only — not portable. Replace any AI calls that need it
# with your own provider (OpenAI, Anthropic, etc.) and add that key as a secret.
