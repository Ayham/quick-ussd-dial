# =============================================================================
# Portable cutover kit — environment variables
# Target project ref: tebyyidgcsivzslaohxd
# Copy to `.env` in the project root AFTER forking away from Lovable Cloud.
# NEVER commit a filled-in copy of this file.
# =============================================================================

# ---- Frontend (Vite, public — safe to ship in the browser bundle) ----------
VITE_SUPABASE_URL=https://tebyyidgcsivzslaohxd.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=REPLACE_WITH_ANON_KEY
VITE_SUPABASE_PROJECT_ID=tebyyidgcsivzslaohxd
VITE_ADMIN_EMAILS=you@example.com

# ---- Server / migration only (NEVER expose to the browser) -----------------
# Anon (publishable) key — same value as VITE_SUPABASE_PUBLISHABLE_KEY, used by shell scripts
SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY
# Service-role key — bypasses RLS. Only used by edge functions and one-shot admin scripts.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY
# Personal access token for the Supabase CLI (`supabase login --token`)
SUPABASE_ACCESS_TOKEN=REPLACE_WITH_PAT

# ---- Database connection strings (used by export/import/verify scripts) ----
# Pooled connection (port 6543) — use for app runtime if you ever add server code
SUPABASE_DB_URL=postgresql://postgres.tebyyidgcsivzslaohxd:REPLACE_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — REQUIRED for psql, pg_dump, migrations, COPY
SUPABASE_DB_URL_DIRECT=postgresql://postgres:REPLACE_DB_PASSWORD@db.tebyyidgcsivzslaohxd.supabase.co:5432/postgres

# ---- Source (old) project connection — used only for one-time data export --
# Ask Lovable support (or use `Cloud → Advanced → Export data`) for the read-only URL.
SOURCE_DB_URL_DIRECT=postgresql://postgres:REPLACE_OLD_DB_PASSWORD@db.jwfsiqkvzmttkuxldkrq.supabase.co:5432/postgres

# ---- Edge Function secrets (set with `supabase secrets set --env-file`) ----
# LOVABLE_API_KEY is NOT portable. Replace any code path that used it with
# your own LLM/provider key and add it here:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ---- OAuth (configured in Supabase Dashboard → Authentication → Providers) -
# Do NOT put OAuth client secrets in this file — they live in the Supabase dashboard.
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=... (dashboard only)

# ---- App URLs (used by Supabase Auth redirect allow-list) ------------------
APP_SITE_URL=https://your-domain.example
APP_REDIRECT_URLS=https://your-domain.example,https://your-domain.example/auth,http://localhost:5173,http://localhost:5173/auth
